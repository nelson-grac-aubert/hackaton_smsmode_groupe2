generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model OtpApp {
  id     String @id @default(cuid())
  name   String
  mail   String @unique
  apiKey String @unique

  ttlSeconds     Int @default(300)
  codeLength     Int @default(6)
  maxAttempts    Int @default(3)
  resendCooldown Int @default(30)

  oneTapEnabled     Boolean @default(true)
  verifyRedirectUrl String

  otpMode OtpMode @default(CLASSIC)

  senderLabel     String  @default("Verification")
  logoUrl         String?
  cardTitle       String  @default("Code de vérification")
  messageTemplate String  @default("Votre code {{brand}} est valable {{ttl}} min.")

  allowedCountries String[] @default([])
  rateLimitPhone   Int      @default(5)
  rateLimitIp      Int      @default(20)
  reportEnabled    Boolean  @default(true)

  challenges OtpTransaction[]
  createdAt  DateTime         @default(now())
}

model OtpTransaction {
  id    String @id @default(cuid())
  appId String
  app   OtpApp @relation(fields: [appId], references: [id])

  phoneHash   String
  sessionId   String
  codeHash    String
  tapToken    String?  @unique
  tapUsed     Boolean  @default(false)
  promptDigit Int?

  status   OtpStatus @default(PENDING)
  attempts Int       @default(0)
  channel  Channel   @default(RCS)

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  BLOCKED
  REPORTED
}

enum Channel {
  RCS
  SMS
}

enum OtpMode {
  CLASSIC
  GOOGLE_PROMPT
}
